{
  "name": "Booking",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Customer full name"
    },
    "phone": {
      "type": "string",
      "description": "Customer phone number"
    },
    "email": {
      "type": "string",
      "description": "Customer email"
    },
    "vehicle": {
      "type": "string",
      "description": "Vehicle make and model"
    },
    "year": {
      "type": "string",
      "description": "Vehicle year"
    },
    "service": {
      "type": "string",
      "enum": [
        "interior",
        "exterior",
        "ceramic",
        "full",
        "unsure"
      ],
      "description": "Service type requested"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Preferred appointment date"
    },
    "time": {
      "type": "string",
      "description": "Preferred appointment time"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes from customer"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "confirmed",
        "completed",
        "cancelled"
      ],
      "default": "new",
      "description": "Booking status"
    },
    "calendarEventId": {
      "type": "string",
      "description": "Google Calendar event ID for this booking"
    },
    "calendarBlockEventId": {
      "type": "string",
      "description": "Google Calendar block event ID (all-day booked marker) for this booking"
    }
  },
  "required": [
    "name",
    "phone",
    "vehicle",
    "service",
    "date",
    "time"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}